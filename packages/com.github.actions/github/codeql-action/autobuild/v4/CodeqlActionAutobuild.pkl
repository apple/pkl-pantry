/// Attempt to automatically build the code. Only used for analyzing languages that require a build. Use the `build-mode: autobuild` input in the `init` action instead.
module com.github.actions.github.`codeql-action`.autobuild.v4.CodeqlActionAutobuild

extends ".../AbstractTypedStep.pkl"

fixed action: "github/codeql-action/autobuild"

fixed version: "v4"

with: With?

class With {
  /// GitHub token to use for authenticating with this instance of GitHub. The token needs the `security-events: write` permission.
  ///
  /// Default if unspecified: `"${{ github.token }}"`
  token: String?

  /// Default if unspecified: `"${{ toJson(matrix) }}"`
  matrix: String?

  /// Run the autobuilder using this path (relative to $GITHUB_WORKSPACE) as working directory. If this input is not set, the autobuilder runs with $GITHUB_WORKSPACE as its working directory.
  `working-directory`: String?
}
