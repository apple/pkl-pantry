/// [Experimental] Start HTTP proxy server. This action is for internal GitHub used only and will change without notice.
module com.github.actions.github.`codeql-action`.`start-proxy`.v4.CodeqlActionStartProxy

extends ".../AbstractTypedStep.pkl"

fixed action: "github/codeql-action/start-proxy"

fixed version: "v4"

with: With?

class With {
  /// The URLs and credentials of package registries
  ///
  /// Default if unspecified: `"[]"`
  registry_secrets: String?

  /// Base64 encoded JSON configuration for the URLs and credentials of the package registries
  registries_credentials: String?

  /// GitHub token to use for authenticating with this instance of GitHub. The token must be the built-in GitHub Actions token, and the workflow must have the `security-events: write` permission. Most of the time it is advisable to avoid specifying this input so that the workflow falls back to using the default value.
  ///
  /// Default if unspecified: `"${{ github.token }}"`
  token: String?

  /// The programming language to setup the proxy for the correct ecosystem
  language: String?

  /// Default if unspecified: `"${{ toJson(matrix) }}"`
  matrix: String?
}
