/// Converts a Kubernetes YAML manifest file to Pkl.
///
/// Evaluating the generated Pkl file will output (an equivalent of) the original YAML.
/// Evaluating multiple generated Pkl files at once will output a single YAML stream.
///
/// ## Prerequisites
///
/// * The `pkl` command is [installed](https://pkl-lang.org/main/current/pkl-cli/index.html#installation).
///
/// ## Usage
///
/// To convert _deployment.yml_ to _deployment.pkl_, run:
/// ```
/// pkl run package://pkg.pkl-pang.org/pkl-pantry/k8s.contrib@<version>#/convert.pkl --input deployment.yml \
///     -o deployment.pkl
/// ```
///
/// To validate the generated Pkl file, run `pkl eval deployment.pkl`.
///
/// ## Known limitations
///
/// * YAML comments are not preserved.
/// * YAML aliases are inlined.
///
/// ## Converting custom resource definitions
///
/// If you need to convert custom resource definitions, you will need to use the lower level Converter library.
@ModuleInfo { minPklVersion = "0.31.0" }
module k8s.contrib.convert

extends "pkl:Command"

import "pkl:platform"

import "@uri/URI.pkl"

import "Converter.pkl"

command {
  name = "pkl-convert-k8s"
}

options: Options

class Options {
  @Flag { completionCandidates = "paths"; metavar = "path-or-uri" }
  input: String
}

local inputUri =
  if (options.input.startsWith(Regex(#"\w+:"#)))
    options.input // absolute URI
  else if (options.input.startsWith("/"))
    "file://\(options.input)" // absolute file path
  else // relative file path
    let (pwd = read("env:PWD"))
    let (
      path =
        if (platform.current.operatingSystem.name == "Windows")
          "/\(pwd)/\(options.input)".replaceAll("\\", "/")
        else
          "\(pwd)/\(options.input)"
    )
      "file://\(URI.encode(path))"

output {
  text = new Converter { input = read(inputUri) }.result
}
